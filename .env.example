# Docker Postgres (권장) — `npm run docker:up` 후 데이터가 볼륨에 유지됩니다.
# `npm run dev` 는 USE_PGLITE 없이 DATABASE_URL 로만 연결합니다.
DATABASE_URL="postgresql://tmap:tmap@127.0.0.1:5433/tmap?schema=public"
# 첫 설정: `npx prisma migrate deploy`

# Docker 없이 빠른 로컬만: `npm run dev:pglite` (USE_PGLITE=1, 재시작 시 데이터 소실)
# USE_PGLITE=1

JWT_SECRET="change-me-in-production-use-long-random-string"
# OAuth Web client ID (same as frontend VITE_GOOGLE_CLIENT_ID). Loaded from project-root .env even if cwd differs.
GOOGLE_CLIENT_ID=""
# Same Web client ID as frontend VITE_GOOGLE_CLIENT_ID (GIS credential audience)
GEMINI_API_KEY=""
# Optional; default gemini-2.5-flash-lite
# GEMINI_MODEL="gemini-2.5-flash-lite"
# Comma-separated origins for browser (e.g. http://localhost:5173)
# CORS_ORIGIN="http://localhost:5173"

# Cluster notes: optional data:image URLs for local dev only (default: reject)
# ALLOW_CLUSTER_NOTE_DATA_IMAGE_URLS=true
# Optional HTTPS image host allowlist (comma-separated hostnames)
# CLUSTER_NOTE_IMAGE_URL_ALLOWED_HOSTS=cdn.example.com,storage.googleapis.com
PORT=3001
HOST=0.0.0.0
